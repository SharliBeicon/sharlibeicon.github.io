---
import "../styles/global.css";
import Github from "../svg/github.svg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Charlie Bacon's place</title>
    <meta name="description" content="Charlie Bacon's place" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <script>
      // Theme initialization - runs before page render to prevent flash
      (function () {
        // Inline version of theme utilities for immediate execution
        function getStoredTheme(): string | null {
          return localStorage.getItem("terminal-theme");
        }

        function getSystemTheme(): "dark" | "light" {
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        function applyTheme(theme: "dark" | "light"): void {
          document.documentElement.setAttribute("data-theme", theme);
        }

        function getEffectiveTheme(): "dark" | "light" {
          const stored = getStoredTheme();
          if (stored && stored !== 'system') {
            return stored as "dark" | "light";
          }
          return getSystemTheme();
        }

        // Initialize theme immediately
        applyTheme(getEffectiveTheme());

        // Listen for system theme changes if no stored preference
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", function (e) {
            const storedTheme = getStoredTheme();
            if (!storedTheme) {
              // Only follow system preference if user hasn't manually set a theme
              const newTheme = e.matches ? "dark" : "light";
              applyTheme(newTheme);
            }
          });
      })();
    </script>
    <div
      class="flex flex-col min-h-screen max-h-screen p-6 md:px-12 gap-4 overflow-hidden bg-[var(--background1)] shadow-lg"
    >
      <slot />

      <footer class="flex-shrink-0">
        <div
          class="flex justify-between items-center py-3 px-4 border-t border-[var(--border-color)] text-sm text-[var(--fg1)]"
        >
          <span class="opacity-80">© 2025 Charlie Bacon</span>
          <a
            href="https://github.com/sharlibeicon/sharlibeicon.github.io"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-[var(--fg1)] no-underline transition-colors duration-200 hover:text-[var(--fg0)]"
          >
            <Github
              width={24}
              height={24}
              class="fill-[var(--fg1)] transition-transform duration-200 hover:scale-110 hover:fill-[var(--fg0)]"
            />
            View on GitHub
          </a>
        </div>
      </footer>
    </div>
  </body>
</html>
