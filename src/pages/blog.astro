---
import Layout from "../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import ThemeToggle from "../components/ThemeToggle.astro";

const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort(
  (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout>
  <header class="bg-[var(--background1)] border-b border-[var(--border-color)]">
    <div class="max-w-4xl mx-auto px-6 mb-4">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl mb-2">Blog</h1>
          <p class="text-[var(--fg1)]">
            Thoughts on development, technology and stuff.
          </p>
        </div>
        <div class="flex items-center gap-4">
          <ThemeToggle />
          <a
            href="/"
            class="text-[var(--fg1)] hover:text-[var(--fg0)] transition-all duration-200 hover:scale-110 flex items-center gap-2 text-sm"
            title="Back to Home"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              ></path>
            </svg>
            Home
          </a>
        </div>
      </div>
    </div>
  </header>
  <main class="mx-auto flex-grow">
    {
      sortedPosts.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-[var(--fg1)] text-md">
            No blog posts yet. Check back soon!
          </p>
        </div>
      ) : (
        <div>
          {sortedPosts.map((post: CollectionEntry<"blog">) => (
            <article class="group">
              <a href={`/blog/${post.slug}`} class="block">
                <div class="border-b border-[var(--border-color)] pb-2 mb-2 hover:border-[var(--border-hover)] transition-all duration-200">
                  <div class="flex items-start justify-between mb-2">
                    <div class="flex-1">
                      <h2 class="text-lg group-hover:text-[var(--blue)] transition-colors duration-200">
                        {post.data.title}
                      </h2>
                    </div>
                    <time class="text-xs text-[var(--fg1)] ml-4 whitespace-nowrap">
                      {formatDate(post.data.pubDate)}
                    </time>
                  </div>

                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex gap-2 mt-2">
                      {post.data.tags.map((tag: string) => (
                        <span class="text-xs text-[var(--blue)] bg-[var(--blue)]/10 px-2 py-1 rounded-full">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>
      )
    }
  </main>
</Layout>


