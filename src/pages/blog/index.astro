---
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import NavBar from "@/components/sections/NavBar.astro";
import Section from "@/components/Section.astro";
import { getReadingTimeLabel } from "@/utils/blog";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog | Charlie Bacon">
    <NavBar />

    <Section>
        <ul class="flex flex-col gap-4 text-[1.05rem]">
            {
                posts.map((post) => (
                    <li class="border-b border-[color:var(--color-muted)]/20 pb-4 last:border-b-0">
                        <a
                            class="accent-link text-xl"
                            href={`/blog/${post.slug}/`}
                        >
                            {post.data.title}
                        </a>
                        <p class="mt-2 text-[color:var(--color-subtle)]">
                            {post.data.description}
                        </p>
                        <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm uppercase tracking-[0.2em]">
                            <p class="text-[color:var(--color-accent)]">
                                {post.data.pubDate.toLocaleDateString("en", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })}
                            </p>
                            <p class="text-[color:var(--color-subtle)]">
                                {getReadingTimeLabel(post.body)}
                            </p>
                        </div>
                    </li>
                ))
            }
        </ul>
    </Section>
</Layout>
